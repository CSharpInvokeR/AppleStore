<Page x:Class="AppleStore.Pages.CustomerPages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Корзина">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="CartGrid" Grid.Row="0" Margin="10" AutoGenerateColumns="False"
                  Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource BorderBrush}"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2}₽}" Width="100"/>
                <DataGridTemplateColumn Header="Количество" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="-" Tag="{Binding ProdID}" Click="BtnDecreaseQuantity_Click" Width="25" Height="25" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Quantity}" Width="35" TextAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                <Button Content="+" Tag="{Binding ProdID}" Click="BtnIncreaseQuantity_Click" Width="25" Height="25" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:N2}₽}" Width="100"/>
                <DataGridTemplateColumn Header="Действия" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить" Tag="{Binding ProdID}" Click="BtnRemoveFromCart_Click" 
                                    Style="{StaticResource SecondaryButton}" FontSize="10" Width="55" Height="25" 
                                    Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="{StaticResource LightGrayBrush}" BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" Margin="10" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="txtTotalAmount" Text="Общая сумма: 0₽" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="txtTotalItems" Text="Товаров: 0" FontSize="12" Foreground="{StaticResource GrayBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnClearCart" Content="Очистить корзину" Style="{StaticResource SecondaryButton}" 
                            Margin="0,0,10,0" Click="btnClearCart_Click"/>
                    <Button x:Name="btnCheckout" Content="Оформить заказ" Style="{StaticResource PrimaryButton}" 
                            Padding="10" Click="btnCheckout_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>