<Page x:Class="AppleStore.Pages.CustomerPages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converter="clr-namespace:AppleStore.Converter"
      Title="Каталог товаров">

    <Page.Resources>
        <converter:ImagePathConverter x:Key="ImagePathConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
            <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbCategory" Width="150" SelectionChanged="CmbCategory_SelectionChanged"/>
            <Button x:Name="btnResetFilters" Content="Сбросить фильтры" Style="{StaticResource SecondaryButton}" 
                    Margin="20,0,0,0" Click="btnResetFilters_Click"/>
            <Button x:Name="btnRefreshCatalog" Content="Обновить каталог" Style="{StaticResource ActionButton}" 
                    Margin="10,0,0,0" Click="btnRefreshCatalog_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="ProductsItemsControl" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource LightGrayBrush}" BorderBrush="{StaticResource BorderBrush}" 
                                BorderThickness="1" Margin="5" Padding="8" Width="200" CornerRadius="5">
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Top">
                                    <Border Width="180" Height="160" Background="#EEEEEE" CornerRadius="5" 
                                            HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Image Stretch="Fill" Width="auto" Height="auto" 
                                               Source="{Binding Foto, Converter={StaticResource ImagePathConverter}}"/>
                                    </Border>
                                    <TextBlock Text="{Binding ProductName}" FontWeight="Bold" FontSize="12" 
                                               TextWrapping="Wrap" Margin="0,0,0,5" HorizontalAlignment="Center"
                                               TextAlignment="Center" MaxHeight="40"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Bottom" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource GrayBrush}" 
                                               FontSize="10" HorizontalAlignment="Center" TextAlignment="Center"
                                               Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:N2}₽}" FontWeight="Bold" 
                                               FontSize="14" Foreground="{StaticResource BlackBrush}" 
                                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding StockQuantity, StringFormat=Остаток: {0} шт.}" 
                                               FontSize="10" Foreground="{StaticResource DarkGrayBrush}" 
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <Button Content="В корзину" Tag="{Binding ProdID}" Click="BtnAddToCart_Click"
                                            Style="{StaticResource ActionButton}" Height="30" FontSize="11" 
                                            Padding="10,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>