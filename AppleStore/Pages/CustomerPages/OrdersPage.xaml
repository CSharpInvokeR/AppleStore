<Page x:Class="AppleStore.Pages.CustomerPages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мои заказы">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
            <Button x:Name="btnRefreshOrders" Content="Обновить" Style="{StaticResource ActionButton}" Click="btnRefreshOrders_Click"/>
        </StackPanel>

        <DataGrid x:Name="OrdersGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="False"
                  Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource BorderBrush}"
                  CanUserResizeColumns="True" CanUserReorderColumns="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding OrdID}" Width="60"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N2}₽}" Width="90"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" Width="130"/>
                <DataGridTemplateColumn Header="Детали" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Подробнее" Tag="{Binding OrdID}" Click="BtnViewOrderDetails_Click" 
                                    Style="{StaticResource SecondaryButton}" FontSize="10" Width="70" Height="25" 
                                    Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>