<Page x:Class="AppleStore.Pages.CustomerPages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мой профиль">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" Width="400">
            <TextBlock Text="Личные данные" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            <StackPanel>
                <TextBlock Text="Имя:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFirstName" Style="{StaticResource InputField}" Margin="0,0,0,15"/>
                <TextBlock Text="Фамилия:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLastName" Style="{StaticResource InputField}" Margin="0,0,0,15"/>
                <TextBlock Text="Телефон:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPhone" Style="{StaticResource InputField}" Margin="0,0,0,15"/>
                <TextBlock Text="Email:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Style="{StaticResource InputField}" Margin="0,0,0,25"/>
                <Button x:Name="btnSaveProfile" Content="Сохранить изменения" Style="{StaticResource PrimaryButton}" Click="btnSaveProfile_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>