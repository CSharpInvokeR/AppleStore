<Page x:Class="AppleStore.Pages.ManagerPages.ManagerCustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Клиенты">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="10" HorizontalAlignment="Left">
            <Button x:Name="btnRefreshCustomers" Content="Обновить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Click="btnRefreshCustomers_Click"/>
            <Button x:Name="btnViewHistory" Content="История заказов" Width="140" Height="35" 
                    Style="{StaticResource ActionButton}" Click="btnViewHistory_Click"/>
        </WrapPanel>

        <DataGrid x:Name="CustomersGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="False"
                  Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource BorderBrush}"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="100"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*" MinWidth="150"/>
                <DataGridTextColumn Header="Заказов" Binding="{Binding OrderCount}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>