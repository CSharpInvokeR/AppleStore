<Window x:Class="AppleStore.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False" Icon="/Resources/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название товара" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtProductName" Grid.Row="1" Height="35" Margin="0,0,0,15" 
                 IsReadOnly="True" Background="#F0F0F0" VerticalContentAlignment="Center" Padding="10,0"/>

        <TextBlock Grid.Row="2" Text="Цена" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPrice" Grid.Row="3" Height="35" Margin="0,0,0,15" 
                 VerticalContentAlignment="Center" Padding="10,0"/>

        <TextBlock Grid.Row="4" Text="Количество на складе" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtStock" Grid.Row="5" Height="35" Margin="0,0,0,20" 
                 VerticalContentAlignment="Center" Padding="10,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" Margin="0,0,20,0" 
                    Style="{StaticResource PrimaryButton}"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" 
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>