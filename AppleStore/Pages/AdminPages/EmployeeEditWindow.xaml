<Window x:Class="AppleStore.Pages.AdminPages.EmployeeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False" Icon="/Resources/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Логин:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtUsername" Grid.Row="1" Height="20" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Пароль:" FontSize="13" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="3" Height="20" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="4" Text="Имя:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtFirstName" Grid.Row="5" Height="20" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="6" Text="Фамилия:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPatronymic" Grid.Row="9" Height="20" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="8" Text="Отчество:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtLastName" Grid.Row="7" Height="20" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" Style="{StaticResource PrimaryButton}"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>