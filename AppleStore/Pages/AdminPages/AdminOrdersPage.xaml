<Page x:Class="AppleStore.Pages.AdminPages.AdminOrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="10" HorizontalAlignment="Left">
            <Button x:Name="btnRefreshOrders" Content="Обновить" Width="120" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnChangeStatus" Content="Изменить статус" Width="120" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnDeleteOrder" Content="Удалить" Width="120" Height="35" 
                    Style="{StaticResource ActionButton}"/>
        </WrapPanel>

        <DataGrid x:Name="OrdersGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="False"
                  Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource BorderBrush}"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerName}" Width="*" MinWidth="150"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N2}₽}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>