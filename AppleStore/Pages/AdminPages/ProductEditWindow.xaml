<Window x:Class="AppleStore.Pages.AdminPages.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="520" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False" Icon="/Resources/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название товара" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtName" Grid.Row="1" Height="35" Margin="0,0,0,15" 
                 VerticalContentAlignment="Center" Padding="10,0"/>

        <TextBlock Grid.Row="2" Text="Категория" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbCategory" Grid.Row="3" Height="35" Margin="0,0,0,15" 
                  VerticalContentAlignment="Center" Padding="5,0"/>

        <TextBlock Grid.Row="4" Text="Цена" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPrice" Grid.Row="5" Height="35" Margin="0,0,0,15" 
                 VerticalContentAlignment="Center" Padding="10,0"/>

        <TextBlock Grid.Row="6" Text="Количество" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtStock" Grid.Row="7" Height="35" Margin="0,0,0,15" 
                 VerticalContentAlignment="Center" Padding="10,0"/>

        <TextBlock Grid.Row="8" Text="Фото (имя файла)" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <Grid Grid.Row="9" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtFoto" Grid.Column="0" Height="35" 
                     VerticalContentAlignment="Center" Padding="10,0"/>
            <Button x:Name="btnSelectFoto" Grid.Column="1" Content="Выбрать" Width="80" Height="35" 
                    Margin="10,0,0,0" Style="{StaticResource SecondaryButton}" Click="btnSelectFoto_Click"/>
        </Grid>

        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSave" Content="Сохранить" Width="110" Height="35" Margin="0,0,20,0" 
                    Style="{StaticResource PrimaryButton}" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="110" Height="35" 
                    Style="{StaticResource SecondaryButton}" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>