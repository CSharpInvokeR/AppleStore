<Page x:Class="AppleStore.Pages.AdminPages.AdminEmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пользователи">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="10" HorizontalAlignment="Left">
            <Button x:Name="btnRefreshEmployees" Content="Обновить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnAddEmployee" Content="Добавить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnEditEmployee" Content="Редактировать" Width="120" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnDeleteEmployee" Content="Удалить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>

            <Separator Width="2" Margin="10,0" Background="#CCCCCC" VerticalAlignment="Center"/>

            <RadioButton x:Name="rbAll" Content="Все" IsChecked="True" Margin="5,0,10,0" 
                         VerticalAlignment="Center" Checked="RbFilter_Checked"/>
            <RadioButton x:Name="rbEmployees" Content="Сотрудники" Margin="5,0,10,0" 
                         VerticalAlignment="Center" Checked="RbFilter_Checked"/>
            <RadioButton x:Name="rbCustomers" Content="Клиенты" Margin="5,0,5,0" 
                         VerticalAlignment="Center" Checked="RbFilter_Checked"/>
        </WrapPanel>

        <DataGrid x:Name="EmployeesGrid" Grid.Row="1" Margin="10" AutoGenerateColumns="False"
                  Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource BorderBrush}"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="100"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic}" Width="100"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="*" MinWidth="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>