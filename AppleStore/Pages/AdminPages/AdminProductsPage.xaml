<Page x:Class="AppleStore.Pages.AdminPages.AdminProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="10" HorizontalAlignment="Left">
            <Button x:Name="btnRefreshProducts" Content="Обновить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnAddProduct" Content="Добавить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnEditProduct" Content="Редактировать" Width="120" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
            <Button x:Name="btnDeleteProduct" Content="Удалить" Width="100" Height="35" 
                    Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>

            <Separator Width="2" Margin="10,0" Background="#CCCCCC" VerticalAlignment="Center"/>

            <RadioButton x:Name="rbTableView" Content="Таблица" IsChecked="True" Margin="5,0,10,0" 
                         VerticalAlignment="Center" Checked="RbTableView_Checked"/>
            <RadioButton x:Name="rbTileView" Content="Плитка" Margin="0,0,5,0" 
                         VerticalAlignment="Center" Checked="RbTileView_Checked"/>
        </WrapPanel>

        <Grid Grid.Row="1">
            <DataGrid x:Name="ProductsGrid" Margin="10" AutoGenerateColumns="False"
                      Background="{StaticResource WhiteBrush}" BorderBrush="{StaticResource BorderBrush}"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      SelectionChanged="ProductsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="*" MinWidth="150"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="100"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2}₽}" Width="100"/>
                    <DataGridTextColumn Header="Количество" Binding="{Binding StockQuantity}" Width="80"/>
                    <DataGridTextColumn Header="Фото" Binding="{Binding Foto}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <ScrollViewer x:Name="tileScrollViewer" Margin="10" Visibility="Collapsed" 
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="tilePanel" HorizontalAlignment="Center"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>