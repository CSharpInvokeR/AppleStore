<Window x:Class="AppleStore.Pages.FormatSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание отчета" Height="420" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False" Icon="/Resources/logo.png">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Название отчета:" FontSize="13" FontWeight="SemiBold" 
                   Margin="0,0,0,5"/>
        <TextBox x:Name="txtReportName" Grid.Row="1" Height="35" Margin="0,0,0,15" 
                 Padding="10,0" VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="2" x:Name="periodPanel" Visibility="Visible">
            <TextBlock Text="Период отчета:" FontSize="13" FontWeight="SemiBold" 
                       Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="С:" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="dpStartDate" Width="150" VerticalContentAlignment="Center"/>
                <TextBlock Text="По:" FontSize="13" VerticalAlignment="Center" Margin="10,0,5,0"/>
                <DatePicker x:Name="dpEndDate" Width="150" VerticalContentAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Формат отчета:" FontSize="13" FontWeight="SemiBold" 
                   Margin="0,0,0,5"/>
        <StackPanel Grid.Row="4" Margin="0,0,0,15" HorizontalAlignment="Left">
            <RadioButton x:Name="rbWord" Content="Word" IsChecked="True" Margin="0,5,0,5" FontSize="13" 
                         Width="60" HorizontalContentAlignment="Left"/>
            <RadioButton x:Name="rbExcel" Content="Excel" Margin="0,5,0,5" FontSize="13" 
                         Width="60" HorizontalContentAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" Margin="0,10,0,0">
            <Button x:Name="btnOk" Content="Создать" Width="100" Height="35" Margin="0,0,15,0" 
                    Style="{StaticResource PrimaryButton}" Click="btnOk_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" 
                    Style="{StaticResource SecondaryButton}" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>