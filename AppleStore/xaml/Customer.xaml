<Window x:Class="AppleStore.Customer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин техники" Height="700" Width="850"
        WindowStartupLocation="CenterScreen" MinHeight="600" MinWidth="700" ResizeMode="CanResize" Icon="/Resources/customer.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BlackBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="TechStore - Магазин техники" FontSize="16" 
                          FontWeight="Bold" Foreground="{StaticResource WhiteBrush}" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="btnCatalog" Content="Каталог" Style="{StaticResource NavButton}" Click="btnCatalog_Click"/>
                    <Button x:Name="btnCart" Content="Корзина" Style="{StaticResource NavButton}" Click="btnCart_Click"/>
                    <Button x:Name="btnOrders" Content="Мои заказы" Style="{StaticResource NavButton}" Click="btnOrders_Click"/>
                    <Button x:Name="btnProfile" Content="Профиль" Style="{StaticResource NavButton}" Click="btnProfile_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserInfo" Foreground="{StaticResource WhiteBrush}" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выйти" Style="{StaticResource SecondaryButton}" 
                           Foreground="{StaticResource WhiteBrush}" BorderBrush="{StaticResource WhiteBrush}" Click="btnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>