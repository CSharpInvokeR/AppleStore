<Window x:Class="AppleStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" 
        Height="625" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="550" MinWidth="400"
        Background="{StaticResource WhiteBrush}" Icon="/Resources/auto.png">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border Width="400" Background="{StaticResource WhiteBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">

                <StackPanel Margin="40" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,40">
                        <Border Width="60" Height="60" Background="{StaticResource BlackBrush}" 
                                CornerRadius="8" HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F3EA;" FontSize="30" HorizontalAlignment="Center" 
                                      VerticalAlignment="Center" Foreground="{StaticResource WhiteBrush}"/>
                        </Border>
                        <TextBlock Text="TechStore" FontSize="26" FontWeight="Bold" 
                                  Foreground="{StaticResource BlackBrush}" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        <TextBlock Text="Вход в систему" FontSize="14" Foreground="{StaticResource GrayBrush}" 
                                  HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Логин" FontSize="13" FontWeight="SemiBold" 
                                  Foreground="{StaticResource BlackBrush}" Margin="0,0,0,8"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                Background="{StaticResource LightGrayBrush}" CornerRadius="4">
                            <TextBox x:Name="txtUsername" Style="{StaticResource InputField}" BorderThickness="0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold" 
                                  Foreground="{StaticResource BlackBrush}" Margin="0,0,0,8"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                                Background="{StaticResource LightGrayBrush}" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="txtPassword" Grid.Column="0" 
                                            Style="{StaticResource PasswordField}" BorderThickness="0" PasswordChar="•"/>
                                <TextBox x:Name="txtPasswordVisible" Grid.Column="0" 
                                        Style="{StaticResource InputField}" BorderThickness="0" Visibility="Collapsed"/>
                                <CheckBox x:Name="chkShowPassword" Grid.Column="1" Content="&#x1F441;" FontSize="12" 
                                         Margin="0,0,10,0" VerticalAlignment="Center" Background="Transparent" 
                                         BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Button x:Name="btnLogin" Content="Войти" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>